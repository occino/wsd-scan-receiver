# Host paths used by docker-compose.yml.
# Copy this file to .env and adjust the values for your machine.

# Host directory where received scan files are written.
SCAN_DIR=./scans

# Raw incoming HTTP/SOAP payloads are written here when DEBUG=true.
DEBUG_DUMPS_DIR=./debug-dumps

# Stores the generated WSD endpoint UUID so scanners see a stable target.
DATA_DIR=./data

# User/group used inside the container for writing bind-mounted files.
# On most single-user Linux systems, 1000:1000 matches the desktop user.
PUID=1000
PGID=1000

# Service configuration passed into the container.
WSD_DEVICE_NAME=Paperless
# Hostname inside the container.
# Keep it DNS-safe: letters, numbers, and hyphens; no spaces.
WSD_HOSTNAME=Paperless
# Optional stable endpoint ID. Preferred format: urn:uuid:<uuid>.
WSD_UUID=
WSD_HTTP_PORT=5357
WSD_HOST=
WSD_INTERFACE=
WSD_SUBSCRIBE_ENABLED=false
WSD_SUBSCRIBE_INTERVAL_SECONDS=60
WSD_SCANNER_IP=
MAX_POST_BYTES=104857600

# WS-Scan ticket parameters. These defaults match the Epson ET-2750 values that
# were observed to work. Supported values depend on the scanner firmware.
#
# SCAN_FORMAT: exif, tiff-single-uncompressed
# SCAN_INPUT_SOURCE: Auto, Platen
# SCAN_CONTENT_TYPE: Text, Photo, Mixed
# SCAN_COLOR_PROCESSING: RGB24, Grayscale8, BlackAndWhite1
# SCAN_RESOLUTION: 100, 300
# SCAN_COMPRESSION_QUALITY: 1-100, only useful for compressed formats like exif
# SCAN_IMAGES_TO_TRANSFER: usually 1
# SCAN_WIDTH/HEIGHT and SCAN_REGION_*: WSD units from scanner capabilities.
#   Epson ET-2750 platen default/full region is 8500 x 11700.
# SCAN_BRIGHTNESS/CONTRAST/SHARPNESS: scanner-dependent signed integers; 0 is neutral.
# SCAN_ROTATION: 0, 90, 180, 270
# SCAN_SCALING_WIDTH/HEIGHT: percent, 100 means no scaling.
SCAN_FORMAT=exif
SCAN_INPUT_SOURCE=Auto
SCAN_CONTENT_TYPE=Text
SCAN_COLOR_PROCESSING=RGB24
SCAN_RESOLUTION=100
SCAN_COMPRESSION_QUALITY=50
SCAN_IMAGES_TO_TRANSFER=1
SCAN_WIDTH=8500
SCAN_HEIGHT=11700
SCAN_REGION_X=0
SCAN_REGION_Y=0
SCAN_REGION_WIDTH=8500
SCAN_REGION_HEIGHT=11700
SCAN_BRIGHTNESS=0
SCAN_CONTRAST=0
SCAN_SHARPNESS=0
SCAN_ROTATION=0
SCAN_SCALING_WIDTH=100
SCAN_SCALING_HEIGHT=100

WSD_DEBUG=false
LOG_LEVEL=INFO
