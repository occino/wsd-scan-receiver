# Host paths used by docker-compose.yml.
# Copy this file to .env and adjust the values for your machine.

# Use your Paperless-ngx consume directory here if desired.
CONSUME_DIR=./consume

# Raw incoming HTTP/SOAP payloads are written here when DEBUG=true.
DEBUG_DUMPS_DIR=./debug-dumps

# Stores the generated WSD endpoint UUID so scanners see a stable target.
DATA_DIR=./data

# User/group used inside the container for writing bind-mounted files.
# On most single-user Linux systems, 1000:1000 matches the desktop user.
PUID=1000
PGID=1000

# Service configuration passed into the container.
WSD_DEVICE_NAME=Paperless
# Hostname inside the container.
# Keep it DNS-safe: letters, numbers, and hyphens; no spaces.
WSD_HOSTNAME=Paperless
# Optional stable endpoint ID. Preferred format: urn:uuid:<uuid>.
WSD_UUID=
WSD_HOST=
WSD_INTERFACE=
WSD_SUBSCRIBE_ENABLED=false
WSD_SUBSCRIBE_INTERVAL_SECONDS=60
EPSON_PRINTER_IP=
WSD_DEBUG=false
LOG_LEVEL=INFO
